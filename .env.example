# Lemon Squeezy (required for checkout + paywall unlock)
NEXT_PUBLIC_LEMON_SQUEEZY_STORE_ID=
NEXT_PUBLIC_LEMON_SQUEEZY_PRODUCT_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Stripe (required for webhook verification)
STRIPE_WEBHOOK_SECRET=

# Optional: global Stripe key fallback (dashboard connect flow stores per-account key)
STRIPE_SECRET_KEY=

# Optional: monitor endpoint protection for external cron triggers
MONITOR_CRON_SECRET=

# Optional: email alert delivery (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_FROM_EMAIL=

# Optional: SMS alert delivery (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
